---
const { href, text } = Astro.props;
---

<a href={href}>
    {text}
</a>

<style>
    a {
        display: inline-block;
        background-color: tomato;
        color: black;
        font-weight: 900;
        padding: 0.5em 1em;
        border-radius: 1em;
        text-decoration: none;
    }
</style>